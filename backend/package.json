{
  "name": "prisma-ai-backend",
  "version": "1.0.0",
  "description": "PrismaAI Backend - Solana Smart Transaction Stack",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
